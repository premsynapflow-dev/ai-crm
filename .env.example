DATABASE_URL=postgresql://postgres:YOUR_SUPABASE_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres
SECRET_KEY=replace-with-a-32-character-minimum-secret-key
ENVIRONMENT=dev
ALLOWED_ORIGINS=http://127.0.0.1:8000,http://localhost:8000,https://synapflow.up.railway.app

GEMINI_API_KEY=YOUR_GEMINI_API_KEY_HERE
OPENAI_API_KEY=
SLACK_WEBHOOK_URL=

ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-admin-password

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=

# Production URL
APP_BASE_URL=https://synapflow.up.railway.app

# Local development
# APP_BASE_URL=http://127.0.0.1:8000
SQLITE_QUEUE_PATH=data/jobs.db
REQUEST_LOG_RETENTION_DAYS=30

# Gmail / Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Optional shared callback when you use a single Gmail OAuth flow
GOOGLE_REDIRECT_URI=
# Optional per-flow overrides. If unset, callbacks are derived from APP_BASE_URL:
# /auth/gmail/callback and /integrations/gmail/callback
GOOGLE_INBOXES_OAUTH_REDIRECT_URI=
GOOGLE_INTEGRATIONS_OAUTH_REDIRECT_URI=
GMAIL_PUBSUB_TOPIC=
GMAIL_WATCH_LABEL_IDS=

RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_WEBHOOK_SECRET=

JWT_SECRET_KEY=
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30

# Error Tracking (Optional)
SENTRY_DSN=
